SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Grafana URL (no trailing slash) reachable from users' browsers for the link:
GRAFANA_APP_URL=https://grafana.example.com

# Base URL the bridge uses to call the plugin API (often same as GRAFANA_APP_URL):
GRAFANA_URL=https://grafana.example.com

# --- Grafana auth (pick ONE method) ---

# Option A: Basic auth (recommended for multi-org — works across all orgs):
GRAFANA_USERNAME=admin
GRAFANA_PASSWORD=admin

# Option B: Service account token (org-1-scoped — only works for single-org):
# GRAFANA_TOKEN=glsa_...

# Same value as plugin secureJsonData.slackBridgeSecret:
SLACK_BRIDGE_SECRET=generate-a-long-random-string
