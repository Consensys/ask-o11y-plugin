# =============================================================================
# Ask O11y Plugin - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# REQUIRES:
# 1. Grafana LLM Plugin - configured with an AI provider API key
# 2. Grafana Service Account - for MCP tool execution and LLM calls
# See README.md for full setup instructions.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM API Key (REQUIRED)
# -----------------------------------------------------------------------------
# Used by the Grafana LLM plugin. Configure in Grafana UI or here.
# Get yours from: https://console.anthropic.com/ or https://platform.openai.com/api-keys
LLM_API_KEY=your-anthropic-or-openai-api-key-here

# -----------------------------------------------------------------------------
# Grafana
# -----------------------------------------------------------------------------
GRAFANA_VERSION=12.3.1
GRAFANA_IMAGE=grafana
DEVELOPMENT=false
ANONYMOUS_AUTH_ENABLED=false

# -----------------------------------------------------------------------------
# Grafana Service Account (REQUIRED)
# -----------------------------------------------------------------------------
# Create in Grafana UI: Configuration → Service Accounts → Add service account
# Assign Admin/Editor (full access) or Viewer (read-only), then create a token.
#
# Self-hosted only - enable these feature toggles in your Grafana config:
#   GF_FEATURE_TOGGLES_ENABLE=externalServiceAccounts
#   GF_AUTH_MANAGED_SERVICE_ACCOUNTS_ENABLED=true
GRAFANA_SERVICE_ACCOUNT_TOKEN=your-grafana-service-account-token-here

# -----------------------------------------------------------------------------
# Prometheus Datasource (Optional)
# -----------------------------------------------------------------------------
# When set, provisions a Prometheus datasource with basic auth.
PROM_URL=
O11Y_USER=
O11Y_PWD=

# -----------------------------------------------------------------------------
# Redis (Optional, recommended for production)
# -----------------------------------------------------------------------------
# Enables persistent session storage. Without Redis, sessions are in-memory
# and lost on Grafana restart.
#
# GF_PLUGIN_ASKO11Y_REDIS=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Debug Logging (Optional)
# -----------------------------------------------------------------------------
# GF_LOG_LEVEL=debug
# GF_LOG_FILTERS=plugins.consensys-asko11y-app:debug

# =============================================================================
# Setup Checklist
# =============================================================================
# [ ] 1. Install Grafana LLM plugin
# [ ] 2. Configure LLM_API_KEY above (or in Grafana UI)
# [ ] 3. Create Grafana service account + token
# [ ] 4. Set GRAFANA_SERVICE_ACCOUNT_TOKEN above
# [ ] 5. Self-hosted: enable externalServiceAccounts feature toggle
# [ ] 6. Install grafana-mcp-app plugin
# [ ] 7. Configure MCP server in Ask O11y settings (UI or provisioning)
# [ ] 8. Verify MCP server shows Healthy in Ask O11y configuration
# [ ] 9. Navigate to Apps → Ask O11y and test
# =============================================================================
